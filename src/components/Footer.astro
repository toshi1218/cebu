---
import { useTranslations, getLocalizedPath } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
import { LINE_URL } from "../lib/contact";
interface Props {
  lang: string;
}
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
function lp(p: string) {
  return getLocalizedPath(p, lang);
}
---

<footer class="site-footer">
  <div class="container ft-grid">
    <div class="ft-brand">
      <div class="ft-logo">{t("footer.brand")}</div>
      <p>{t("footer.tagline")}</p>
    </div>
    <div class="ft-links">
      <h4>{t("nav.services")}</h4>
      <a href={lp("/services")}>{t("services.psa.title")}</a>
      <a href={lp("/services")}>{t("services.nbi.title")}</a>
      <a href={lp("/services")}>{t("services.dfa.title")}</a>
      <a href={lp("/services")}>{t("services.translation.title")}</a>
    </div>
    <div class="ft-links">
      <h4>{lang === "ja" ? "会社情報" : "Company"}</h4>
      <a href={lp("/about")}>{t("nav.about")}</a>
      <a href={lp("/contact")}>{t("nav.contact")}</a>
      {
        lang === "ja" && (
          <a href={LINE_URL} target="_blank" rel="noopener" class="ft-line">
            LINEで相談
          </a>
        )
      }
    </div>
    <div class="ft-info">
      <p>{t("footer.operator")}</p>
      <p>{t("footer.hq")}</p>
      <p>{t("footer.ph")}</p>
    </div>
  </div>
  <div class="ft-bottom">
    <div class="container">
      <p>{t("footer.copy")}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: rgba(255, 255, 255, 0.8);
    padding-top: 64px;
  }
  .ft-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 40px;
    padding-bottom: 48px;
  }
  .ft-logo {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .ft-brand p {
    font-size: 0.9rem;
    line-height: 1.7;
    opacity: 0.7;
  }
  .ft-links h4 {
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .ft-links a {
    display: block;
    font-size: 0.9rem;
    opacity: 0.7;
    padding: 4px 0;
    transition: opacity 0.2s;
  }
  .ft-links a:hover {
    opacity: 1;
  }
  .ft-line {
    display: inline-block !important;
    margin-top: 8px;
    padding: 6px 14px !important;
    background: #06c755;
    color: #fff !important;
    border-radius: 999px;
    font-size: 0.85rem !important;
    font-weight: 600;
    opacity: 1 !important;
  }
  .ft-line:hover {
    background: #05b64d;
  }
  .ft-info p {
    font-size: 0.85rem;
    opacity: 0.6;
    line-height: 1.8;
  }
  .ft-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 20px 0;
  }
  .ft-bottom p {
    font-size: 0.8rem;
    opacity: 0.5;
    text-align: center;
  }
  @media (max-width: 768px) {
    .ft-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .ft-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .ft-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
