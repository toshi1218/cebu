---
import { useTranslations, getLocalizedPath } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
interface Props {
  lang: string;
}
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
const path = Astro.url.pathname;
const currentSlug = path.replace(`/${lang}`, "") || "/";

function navLink(slug: string) {
  return getLocalizedPath(slug, lang);
}
function isActive(slug: string) {
  return currentSlug === slug || currentSlug === slug + "/";
}

const navLinks = [
  { key: "nav.home" as const, path: "/" },
  { key: "nav.services" as const, path: "/services" },
  { key: "nav.cases" as const, path: "/cases" },
  { key: "nav.about" as const, path: "/about" },
];

const currentPath = Astro.url.pathname;
const jaPath = currentPath.replace(/^\/(en|ja)/, "/ja") || "/ja";
const enPath = currentPath.replace(/^\/(en|ja)/, "/en") || "/en";
---

<header class="site-header">
  <div class="container hdr">
    <a href={navLink("/")} class="logo">IGRS</a>
    <nav class="nav-desk">
      <a href={navLink("/")} class:list={{ active: isActive("/") }}
        >{t("nav.home")}</a
      >
      <a
        href={navLink("/services")}
        class:list={{ active: isActive("/services") }}>{t("nav.services")}</a
      >
      <a href={navLink("/cases")} class:list={{ active: isActive("/cases") }}
        >{t("nav.cases")}</a
      >
      <a href={navLink("/about")} class:list={{ active: isActive("/about") }}
        >{t("nav.about")}</a
      >
    </nav>
    <div class="hdr-right">
      <div class="lang-sw">
        <a href={jaPath} class:list={{ active: lang === "ja" }}>JP</a>
        <span>|</span>
        <a href={enPath} class:list={{ active: lang === "en" }}>EN</a>
      </div>
      <a href={navLink("/contact")} class="btn btn-primary hdr-cta"
        >{t("nav.contact")}</a
      >
    </div>
    <button class="hamburger" id="ham" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="nav-mob" id="mob-nav" hidden>
    <a href={navLink("/")}>{t("nav.home")}</a>
    <a href={navLink("/services")}>{t("nav.services")}</a>
    <a href={navLink("/cases")}>{t("nav.cases")}</a>
    <a href={navLink("/about")}>{t("nav.about")}</a>
    <a href={navLink("/contact")} class="mob-cta">{t("nav.contact")}</a>
    <div class="mob-lang">
      <a href={jaPath} class:list={{ active: lang === "ja" }}>JP</a>
      <span>|</span>
      <a href={enPath} class:list={{ active: lang === "en" }}>EN</a>
    </div>
  </nav>
</header>

<script>
  const ham = document.getElementById("ham");
  const mob = document.getElementById("mob-nav");
  ham?.addEventListener("click", () => {
    const open = mob?.hidden === false;
    if (mob) mob.hidden = open;
    ham.classList.toggle("open", !open);
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }
  .hdr {
    display: flex;
    align-items: center;
    height: 64px;
    gap: 32px;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 0.05em;
  }
  .nav-desk {
    display: flex;
    gap: 28px;
    flex: 1;
  }
  .nav-desk a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-light);
    transition: color 0.2s;
    padding: 4px 0;
  }
  .nav-desk a:hover,
  .nav-desk a.active {
    color: var(--primary);
  }
  .nav-desk a.active {
    border-bottom: 2px solid var(--accent);
  }
  .hdr-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .lang-sw {
    display: flex;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .lang-sw a {
    color: var(--text-muted);
    font-weight: 500;
  }
  .lang-sw a.active {
    color: var(--primary);
    font-weight: 700;
  }
  .hdr-cta {
    padding: 8px 20px;
    font-size: 0.85rem;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    transition: all 0.2s;
  }
  .hamburger.open span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }
  .nav-mob {
    background: #fff;
    border-top: 1px solid var(--border);
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .nav-mob a {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    padding: 8px 0;
  }
  .mob-cta {
    background: var(--accent);
    color: #fff !important;
    text-align: center;
    padding: 12px !important;
    border-radius: var(--radius);
    font-weight: 600;
  }
  .mob-lang {
    display: flex;
    gap: 8px;
    justify-content: center;
    font-size: 0.85rem;
    color: var(--text-muted);
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }
  .mob-lang a.active {
    font-weight: 700;
    color: var(--primary);
  }
  @media (max-width: 768px) {
    .nav-desk,
    .hdr-right {
      display: none;
    }
    .hamburger {
      display: flex;
      margin-left: auto;
    }
  }
</style>
