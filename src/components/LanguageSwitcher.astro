---
interface Props {
  currentLang: string;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;

// Swap /ja/... <-> /en/... keeping the rest of the path intact
const jaPath = currentPath.replace(/^\/(en|ja)(\/|$)/, "/ja$2") || "/ja";
const enPath = currentPath.replace(/^\/(en|ja)(\/|$)/, "/en$2") || "/en";
---

<div class="lang-switcher" role="navigation" aria-label="Language switcher">
  <a
    href={jaPath}
    class={`lang-option${currentLang === "ja" ? " lang-option--active" : ""}`}
    lang="ja"
    hreflang="ja"
    aria-current={currentLang === "ja" ? "true" : undefined}
  >
    JP
  </a>
  <span class="lang-divider" aria-hidden="true">|</span>
  <a
    href={enPath}
    class={`lang-option${currentLang === "en" ? " lang-option--active" : ""}`}
    lang="en"
    hreflang="en"
    aria-current={currentLang === "en" ? "true" : undefined}
  >
    EN
  </a>
</div>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
  }

  .lang-option {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    padding: 0.2rem 0.3rem;
    border-radius: var(--border-radius-sm);
    transition: color 0.2s ease;
    line-height: 1;
  }

  .lang-option:hover {
    color: var(--primary-color);
  }

  .lang-option--active {
    color: var(--primary-color);
    font-weight: var(--font-weight-bold);
    pointer-events: none;
  }

  .lang-divider {
    color: var(--border-color);
    user-select: none;
    line-height: 1;
  }
</style>
