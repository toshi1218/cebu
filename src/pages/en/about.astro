---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title={t("about.title") + " | IGRS"} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("about.title")}</h1>
        <p>{t("about.sub")}</p>
      </div>
    </div>

    <!-- Company Information -->
    <section>
      <div class="container">
        <div class="section-title">
          <h2>Company Overview</h2>
          <p>IGRS is a Japanese corporation operating a dedicated Philippine document procurement office in Cebu City.</p>
        </div>
        <div class="company-table">
          <dl class="company-row">
            <dt>{t("about.name.label")}</dt>
            <dd>{t("about.name.value")}</dd>
          </dl>
          <dl class="company-row">
            <dt>{t("about.founded.label")}</dt>
            <dd>{t("about.founded.value")}</dd>
          </dl>
          <dl class="company-row">
            <dt>{t("about.hq.label")}</dt>
            <dd>{t("about.hq.value")}</dd>
          </dl>
          <dl class="company-row">
            <dt>{t("about.cebu.label")}</dt>
            <dd>{t("about.cebu.value")}</dd>
          </dl>
          <dl class="company-row">
            <dt>{t("about.biz.label")}</dt>
            <dd>{t("about.biz.value")}</dd>
          </dl>
          <dl class="company-row">
            <dt>{t("about.ceo.label")}</dt>
            <dd>{t("about.ceo.value")}</dd>
          </dl>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>By the Numbers</h2>
        </div>
        <div class="stats-row">
          <div class="stat">
            <div class="stat-number">4 Weeks</div>
            <div class="stat-label">Standard Delivery Turnaround</div>
          </div>
          <div class="stat">
            <div class="stat-number">80%+</div>
            <div class="stat-label">Business &amp; Law Firm Clients</div>
          </div>
          <div class="stat">
            <div class="stat-number">Weekly</div>
            <div class="stat-label">Progress Updates Per Case</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Story -->
    <section>
      <div class="container">
        <div class="about-content">
          <div class="section-title">
            <h2>Why We Exist</h2>
          </div>
          <div class="grid-2">
            <div class="card">
              <h3>Built for Law Firms</h3>
              <p>IGRS was founded to solve a specific problem: immigration law firms handling Philippine national clients had no reliable, accountable partner for procuring Philippine government documents. Individual brokers offered no visibility, no guarantees, and no professional accountability. We built IGRS to change that.</p>
            </div>
            <div class="card">
              <h3>Cebu-Based, Japan-Operated</h3>
              <p>Our operational structure combines local presence with corporate accountability. Our Cebu City office provides direct access to PSA, NBI, LTO, and DFA offices. Our Japan headquarters provides the legal structure, billing systems, and professional standards that immigration law firms require from a B2B partner.</p>
            </div>
            <div class="card">
              <h3>Corporate Accountability</h3>
              <p>As a registered Japanese corporation, IGRS provides formal B2B services: invoice billing, case management records, weekly progress reporting, and professional correspondence. We operate as a proper business partner — not a freelance broker — which matters when you're managing client immigration cases with real deadlines and legal consequences.</p>
            </div>
            <div class="card">
              <h3>End-to-End, No Surprises</h3>
              <p>We handle every step of Philippine document procurement in-house: appointment booking, government office visits, document authentication at DFA, and DHL international shipping. You provide the required information; we deliver authenticated documents to your office. No subcontracting, no middlemen, no gaps in the chain.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Countries We Serve -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>Who We Work With</h2>
          <p>We serve immigration law firms and related professional service providers across English-speaking markets.</p>
        </div>
        <div class="grid-2">
          <div class="card">
            <h3>United States</h3>
            <p>Immigration attorneys handling K-1, CR-1/IR-1, F-1, H-1B, L-1, and naturalization cases for Philippine national clients. We are familiar with USCIS, NVC, and DOS document standards for Philippine-origin documents.</p>
          </div>
          <div class="card">
            <h3>Canada</h3>
            <p>Canadian immigration lawyers and consultants handling spousal sponsorships, work permits, Express Entry, and Provincial Nominee Program applications for Philippine nationals. IRCC-standard Philippine documents procured and apostilled.</p>
          </div>
          <div class="card">
            <h3>Australia</h3>
            <p>Australian migration agents and solicitors handling partner visas, skilled worker applications, and citizenship cases involving Philippine nationals. We supply Department of Home Affairs-ready Philippine documents.</p>
          </div>
          <div class="card">
            <h3>Other Jurisdictions</h3>
            <p>Because all IGRS documents include DFA apostille authentication, they are legally recognized in any Hague Convention member state. We can support firms in other countries handling Philippine national clients — contact us to discuss your requirements.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={getLocalizedPath("/contact", lang)} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .about-content {
    max-width: 900px;
    margin: 0 auto;
  }
</style>
