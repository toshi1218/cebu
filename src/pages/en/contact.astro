---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout
  title="Contact Us — Get a Free Quote | IGRS Philippine Document Procurement"
  description="Contact IGRS for a free quote on Philippine document procurement. We work with US immigration law firms handling K-1, CR-1, H-1B, naturalization, and other visa cases."
  lang="en"
>
  <Header lang="en" />

  <main>
    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("contact.title")} — {t("contact.subtitle")}</h1>
        <p>{t("contact.text")}</p>
      </div>
    </div>

    <!-- Contact Content -->
    <section>
      <div class="container">
        <div class="contact-layout">

          <!-- Left: How to reach us -->
          <div class="contact-main">

            <!-- Email -->
            <div class="card contact-card">
              <h2 class="contact-card-title">
                <span class="contact-card-icon" aria-hidden="true">&#9993;</span>
                {t("contact.email")}
              </h2>
              <p class="contact-card-desc">Send us your inquiry and we will respond within one business day with a proposed plan and pricing.</p>
              <a href="mailto:igrs20200601@gmail.com" class="contact-email-link">
                {t("contact.email.address")}
              </a>
            </div>

            <!-- What to include -->
            <div class="card contact-card">
              <h2 class="contact-card-title">What to Include in Your Inquiry</h2>
              <p class="contact-card-desc">To get an accurate quote quickly, please include the following details:</p>
              <ol class="inquiry-list">
                <li>
                  <span class="inquiry-item-label">Document types needed</span>
                  <span class="inquiry-item-desc">e.g., PSA Birth Certificate, NBI Clearance, CENOMAR, DFA Apostille, Translation</span>
                </li>
                <li>
                  <span class="inquiry-item-label">Number of cases / individuals</span>
                  <span class="inquiry-item-desc">How many beneficiaries or sets of documents do you need? Volume discounts apply for 10 or more cases.</span>
                </li>
                <li>
                  <span class="inquiry-item-label">Visa or case type</span>
                  <span class="inquiry-item-desc">e.g., K-1 fiancé visa, CR-1 spouse visa, H-1B, naturalization — this helps us recommend the right document bundle.</span>
                </li>
                <li>
                  <span class="inquiry-item-label">Preferred delivery timeline</span>
                  <span class="inquiry-item-desc">Standard delivery is 4 weeks. Let us know if you have an earlier deadline and we will advise on feasibility.</span>
                </li>
                <li>
                  <span class="inquiry-item-label">Delivery address</span>
                  <span class="inquiry-item-desc">Your firm's address for DHL international delivery.</span>
                </li>
              </ol>

              <div class="inquiry-note">
                <p>Not sure exactly what documents you need? Just describe the case type and we will guide you on the standard document requirements.</p>
              </div>
            </div>
          </div>

          <!-- Right: Business info sidebar -->
          <aside class="contact-sidebar">

            <!-- Business hours -->
            <div class="card sidebar-card">
              <h3 class="sidebar-card-title">{t("contact.hours")}</h3>
              <p class="sidebar-value">{t("contact.hours.value")}</p>
              <p class="sidebar-note">Note: Japan Time (JST) is GMT+9. For US clients, this corresponds to:</p>
              <ul class="tz-list">
                <li><span class="tz-name">Eastern (ET)</span> <span class="tz-time">Mon–Fri 8:00 PM – 5:00 AM (previous day)</span></li>
                <li><span class="tz-name">Central (CT)</span> <span class="tz-time">Mon–Fri 7:00 PM – 4:00 AM (previous day)</span></li>
                <li><span class="tz-name">Pacific (PT)</span> <span class="tz-time">Mon–Fri 5:00 PM – 2:00 AM (previous day)</span></li>
              </ul>
              <p class="sidebar-note-bottom">Email inquiries are welcome at any time. We respond within one business day (Japan business day).</p>
            </div>

            <!-- Response time -->
            <div class="card sidebar-card">
              <h3 class="sidebar-card-title">Response Time</h3>
              <p class="sidebar-value">Within 1 business day</p>
              <p class="sidebar-note">{t("contact.hours.note")}. Quotes are typically provided within the same response.</p>
            </div>

            <!-- Pricing quick ref -->
            <div class="card sidebar-card pricing-ref-card">
              <h3 class="sidebar-card-title">Pricing Reference</h3>
              <div class="pricing-ref-row">
                <span class="ref-label">Standard</span>
                <span class="ref-price">$350 USD</span>
              </div>
              <p class="ref-desc">1 PSA document + DFA Apostille + DHL</p>
              <div class="pricing-ref-row">
                <span class="ref-label">Bundle</span>
                <span class="ref-price">$650 USD</span>
              </div>
              <p class="ref-desc">Multiple documents + DFA Apostille + DHL</p>
              <div class="pricing-ref-row">
                <span class="ref-label">NBI Clearance</span>
                <span class="ref-price">$375 USD</span>
              </div>
              <p class="ref-desc">NBI + DFA Apostille + DHL</p>
              <p class="ref-volume-note">Volume discounts available for 10+ cases. Invoice billing available.</p>
            </div>

            <!-- Company info -->
            <div class="card sidebar-card">
              <h3 class="sidebar-card-title">Company</h3>
              <dl class="sidebar-info-list">
                <div class="sidebar-info-row">
                  <dt>Name</dt>
                  <dd>IGRS Corporation (株式会社IGRS)</dd>
                </div>
                <div class="sidebar-info-row">
                  <dt>Japan HQ</dt>
                  <dd>Wakayama City, Wakayama, Japan</dd>
                </div>
                <div class="sidebar-info-row">
                  <dt>Philippines Office</dt>
                  <dd>Cebu City, Philippines</dd>
                </div>
              </dl>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ Row -->
    <section class="bg-light">
      <div class="container">
        <h2 class="section-title">Common Questions About Getting Started</h2>
        <div class="contact-faq-grid">
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              Do you work with US immigration attorneys directly?
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              Yes. US immigration law firms are our primary English-market clients. We understand the document requirements for USCIS and US consulate submissions and can advise on which Philippine documents your case requires.
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.2.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.2.a")}
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.1.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.1.a")}
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.4.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.4.a")}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container cta-inner">
        <h2 class="cta-heading">Ready to Get Started?</h2>
        <p class="cta-text">Email us at <a href="mailto:igrs20200601@gmail.com" class="cta-email-link">{t("contact.email.address")}</a> with your case details and we'll respond with a complete quote within one business day.</p>
        <div class="cta-group">
          <a href="mailto:igrs20200601@gmail.com" class="btn btn-cta btn-lg">
            Send Us an Email
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  /* Contact layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 2rem;
    align-items: start;
  }

  /* Contact cards */
  .contact-card {
    margin-bottom: 1.5rem;
  }

  .contact-card:last-child {
    margin-bottom: 0;
  }

  .contact-card-title {
    font-size: 1.2rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .contact-card-icon {
    font-size: 1rem;
    color: var(--accent-color);
  }

  .contact-card-desc {
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .contact-email-link {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--primary-color);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .contact-email-link:hover {
    color: var(--accent-color);
  }

  /* Inquiry list */
  .inquiry-list {
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .inquiry-list li {
    line-height: 1.5;
  }

  .inquiry-item-label {
    display: block;
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .inquiry-item-desc {
    display: block;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .inquiry-note {
    background-color: var(--bg-light);
    border-left: 3px solid var(--accent-color);
    border-radius: 0 var(--border-radius-md) var(--border-radius-md) 0;
    padding: 0.875rem 1rem;
    margin-top: 0.25rem;
  }

  .inquiry-note p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-card {
    padding: 1.5rem;
  }

  .sidebar-card-title {
    font-size: 1rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-value {
    font-size: 0.95rem;
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
    margin-bottom: 0.5rem;
  }

  .sidebar-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .sidebar-note-bottom {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    margin-bottom: 0;
    line-height: 1.5;
  }

  /* Timezone list */
  .tz-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .tz-list li {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .tz-name {
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
  }

  .tz-time {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Pricing reference */
  .pricing-ref-card {
    background-color: var(--bg-light);
    border-color: var(--border-color);
  }

  .pricing-ref-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
    margin-bottom: 0.2rem;
  }

  .ref-label {
    font-size: 0.875rem;
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
  }

  .ref-price {
    font-size: 1rem;
    font-weight: var(--font-weight-bold);
    color: var(--primary-color);
  }

  .ref-desc {
    font-size: 0.775rem;
    color: var(--text-muted);
    margin-bottom: 0;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .ref-volume-note {
    font-size: 0.775rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    margin-bottom: 0;
    font-style: italic;
  }

  /* Sidebar info list */
  .sidebar-info-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .sidebar-info-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .sidebar-info-row dt {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .sidebar-info-row dd {
    font-size: 0.875rem;
    color: var(--text-dark);
    margin: 0;
  }

  /* FAQ section */
  .contact-faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .faq-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-q,
  .faq-a {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .faq-q {
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
  }

  .faq-a {
    color: var(--text-light);
  }

  .faq-label {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background-color: var(--primary-color);
    color: #ffffff;
    border-radius: var(--border-radius-sm);
    font-size: 0.8rem;
    font-weight: var(--font-weight-bold);
  }

  .faq-label-a {
    background-color: var(--accent-color);
    color: #000000;
  }

  /* CTA Section */
  .cta-section {
    background-color: var(--primary-color);
    padding: 4rem 0;
  }

  .cta-inner {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .cta-heading {
    color: #ffffff;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .cta-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .cta-email-link {
    color: var(--accent-color);
    font-weight: var(--font-weight-semibold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cta-email-link:hover {
    color: #f0c04a;
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: 1.05rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-sidebar {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .contact-faq-grid {
      grid-template-columns: 1fr;
    }

    .cta-heading {
      font-size: 1.4rem;
    }
  }
</style>
