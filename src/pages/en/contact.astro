---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title={t("contact.title") + " | IGRS"} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("contact.title")}</h1>
        <p>{t("contact.sub")}</p>
      </div>
    </div>

    <!-- Contact Info -->
    <section>
      <div class="container">
        <div class="contact-layout">

          <div class="contact-card card">
            <h2>Get in Touch</h2>
            <p class="contact-intro">{t("contact.text")}</p>

            <div class="contact-row">
              <div class="contact-label">{t("contact.email.label")}</div>
              <div class="contact-value">
                <a href={"mailto:" + t("contact.email")} class="email-link">{t("contact.email")}</a>
              </div>
            </div>

            <div class="contact-row">
              <div class="contact-label">{t("contact.hours.label")}</div>
              <div class="contact-value">
                <strong>{t("contact.hours")}</strong>
                <span class="contact-note-inline">Our team operates from Cebu, Philippines (GMT+9 / Japan Standard Time). Emails sent outside business hours are reviewed and responded to on the next business day.</span>
              </div>
            </div>

            <div class="contact-row">
              <div class="contact-label">Response Time</div>
              <div class="contact-value">
                <strong>{t("contact.note")}</strong>
                <span class="contact-note-inline">For urgent matters, please indicate your deadline in the subject line and we will prioritize your inquiry accordingly.</span>
              </div>
            </div>

            <div class="contact-row">
              <div class="contact-label">What to Include</div>
              <div class="contact-value">
                <ul class="include-list">
                  <li>Visa or immigration case type (e.g., K-1, CR-1, H-1B, naturalization)</li>
                  <li>Documents required (PSA birth certificate, NBI clearance, etc.)</li>
                  <li>Number of cases or applicants</li>
                  <li>Target submission or filing date</li>
                  <li>Delivery destination (US, Canada, Australia, or other)</li>
                  <li>Any specific requirements from USCIS, IRCC, or Home Affairs</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="contact-side">
            <div class="card side-card">
              <h3>Invoice Billing Available</h3>
              <p>We offer invoice billing for all law firm and corporate clients. Tell us your firm's billing requirements and we'll accommodate your accounting cycle.</p>
            </div>
            <div class="card side-card">
              <h3>Volume Pricing</h3>
              <p>Firms submitting 10 or more cases receive volume pricing. We also support ongoing retainer-style arrangements for firms with recurring Philippine document needs.</p>
            </div>
            <div class="card side-card">
              <h3>Turnaround Time</h3>
              <p>Standard turnaround is 4 weeks from order placement to DHL delivery. Rush processing may be available depending on the case type — mention your deadline when you contact us.</p>
            </div>
            <div class="card side-card">
              <h3>Frequently Requested</h3>
              <ul class="faq-mini-list">
                <li>PSA Birth Certificate + DFA Apostille — <strong>$350</strong></li>
                <li>NBI Clearance + DFA Apostille — <strong>$375</strong></li>
                <li>Bundle Package (multiple docs) — <strong>$650</strong></li>
                <li>LTO Driver's Records — <strong>Contact for quote</strong></li>
                <li>Translation — <strong>Contact for quote</strong></li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Process Reminder -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>What Happens After You Email Us</h2>
          <p>Our process is designed to minimize work on your side.</p>
        </div>
        <div class="flow-steps">
          <div class="flow-step">
            <div>
              <h3>We review your inquiry</h3>
              <p>Within one business day, we confirm which documents are needed, expected turnaround, and pricing for your case.</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>You receive a written quote</h3>
              <p>We send a clear, itemized quote with pricing, timeline, and any case-specific notes. No hidden fees.</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>You place the order</h3>
              <p>Confirm the quote and provide the required applicant information. We'll tell you exactly what we need for each document type.</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>We handle everything</h3>
              <p>Our Cebu team visits the relevant government offices — PSA, NBI, LTO, DFA — and handles all procurement steps. You receive weekly progress updates.</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>Documents delivered to your office</h3>
              <p>Authenticated, apostilled documents shipped via DHL with a tracking number. We confirm delivery.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={"mailto:" + t("contact.email")} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 32px;
    align-items: start;
  }
  .contact-intro {
    color: var(--text-light);
    margin-bottom: 28px;
    font-size: 1rem;
    line-height: 1.75;
  }
  .contact-card h2 {
    margin-bottom: 12px;
  }
  .contact-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-row:last-child {
    border-bottom: none;
  }
  .contact-label {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 2px;
  }
  .contact-value strong {
    display: block;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 4px;
  }
  .contact-note-inline {
    display: block;
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-top: 4px;
    line-height: 1.6;
  }
  .include-list {
    list-style: none;
  }
  .include-list li {
    font-size: 0.92rem;
    color: var(--text-light);
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
    padding-left: 16px;
    position: relative;
  }
  .include-list li:last-child {
    border-bottom: none;
  }
  .include-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .contact-side {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .side-card h3 {
    font-size: 1rem;
    margin-bottom: 8px;
  }
  .side-card p {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.7;
  }
  .faq-mini-list {
    list-style: none;
  }
  .faq-mini-list li {
    font-size: 0.88rem;
    color: var(--text-light);
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
  }
  .faq-mini-list li:last-child {
    border-bottom: none;
  }
  .faq-mini-list strong {
    color: var(--accent);
  }
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .contact-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
