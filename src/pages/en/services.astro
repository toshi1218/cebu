---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title={t("services.title") + " | IGRS"} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("services.title")}</h1>
        <p>Complete Philippine government document procurement for immigration law firms in the US, Canada, and Australia.</p>
      </div>
    </div>

    <!-- PSA Certificates -->
    <section>
      <div class="container">
        <div class="service-detail">
          <div class="service-header">
            <span class="service-tag">PSA</span>
            <h2>{t("services.psa.title")}</h2>
          </div>
          <p class="service-lead">Philippine Statistics Authority (PSA) certificates are the foundational documents required in nearly every Philippine immigration case. All PSA documents are issued directly by the Philippine government and carry official security paper and seals.</p>
          <div class="grid-2" style="margin-top: 32px;">
            <div class="card">
              <h3>What's Included</h3>
              <ul class="doc-list">
                <li>PSA Birth Certificate (original security paper)</li>
                <li>PSA Marriage Certificate</li>
                <li>CENOMAR — Certificate of No Marriage Record</li>
                <li>PSA Death Certificate (if applicable)</li>
                <li>DFA apostille authentication (add-on)</li>
                <li>DHL international shipping to your office</li>
              </ul>
            </div>
            <div class="card">
              <h3>Required For</h3>
              <ul class="doc-list">
                <li>K-1 Fiancé Visa petitions (USCIS)</li>
                <li>CR-1 / IR-1 Spouse Visa applications</li>
                <li>F-1 and J-1 student visa applications</li>
                <li>Naturalization and citizenship cases</li>
                <li>Spousal sponsorship (Canada PR, Australia PMV)</li>
                <li>Any immigration case requiring proof of civil status</li>
              </ul>
            </div>
          </div>
          <div class="service-pricing card" style="margin-top: 24px;">
            <div class="pricing-row">
              <span class="pricing-item">PSA Certificate + DFA Apostille + DHL</span>
              <span class="pricing-amount">From $350</span>
            </div>
            <p class="pricing-sub">Turnaround: approximately 4 weeks from order. Volume pricing available for 10+ cases.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- NBI Clearance -->
    <section class="bg-alt">
      <div class="container">
        <div class="service-detail">
          <div class="service-header">
            <span class="service-tag">NBI</span>
            <h2>{t("services.nbi.title")}</h2>
          </div>
          <p class="service-lead">NBI (National Bureau of Investigation) Clearance is the Philippine equivalent of a criminal background check. It is required for nearly all immigration applications involving Philippine nationals, including work visas, spouse visas, and naturalization.</p>
          <div class="grid-2" style="margin-top: 32px;">
            <div class="card">
              <h3>What's Included</h3>
              <ul class="doc-list">
                <li>NBI Clearance (official government-issued)</li>
                <li>In-person representation at NBI offices in Cebu</li>
                <li>Coordination with applicant for biometric requirements</li>
                <li>DFA apostille authentication (add-on)</li>
                <li>DHL international shipping to your office</li>
                <li>Weekly status updates throughout procurement</li>
              </ul>
            </div>
            <div class="card">
              <h3>Required For</h3>
              <ul class="doc-list">
                <li>K-1 Fiancé Visa petitions</li>
                <li>H-1B, L-1, and employment-based visas</li>
                <li>F-1 student visa applications (some consulates)</li>
                <li>Canadian work permits and PR applications</li>
                <li>Australian partner and skilled worker visas</li>
                <li>Naturalization and citizenship applications</li>
              </ul>
            </div>
          </div>
          <div class="service-pricing card" style="margin-top: 24px;">
            <div class="pricing-row">
              <span class="pricing-item">NBI Clearance + DFA Apostille + DHL</span>
              <span class="pricing-amount">$375</span>
            </div>
            <p class="pricing-sub">Turnaround: approximately 4 weeks from order. Bulk pricing available for multiple applicants.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- LTO Driver's Records -->
    <section>
      <div class="container">
        <div class="service-detail">
          <div class="service-header">
            <span class="service-tag">LTO</span>
            <h2>{t("services.lto.title")}</h2>
          </div>
          <p class="service-lead">Land Transportation Office (LTO) records are needed when a Philippine national wishes to convert their Philippine driver's license in their destination country, or when driving history is required as part of an immigration or background verification process.</p>
          <div class="grid-2" style="margin-top: 32px;">
            <div class="card">
              <h3>What's Included</h3>
              <ul class="doc-list">
                <li>Official LTO Driver's Record (driving history)</li>
                <li>License verification and status confirmation</li>
                <li>Direct coordination with LTO regional offices</li>
                <li>DFA apostille authentication (add-on)</li>
                <li>DHL international shipping</li>
              </ul>
            </div>
            <div class="card">
              <h3>Required For</h3>
              <ul class="doc-list">
                <li>Foreign license conversion in US, Canada, Australia</li>
                <li>Employment-based immigration cases requiring driving history</li>
                <li>Background verification for professional visa applications</li>
                <li>Insurance and employment background checks</li>
              </ul>
            </div>
          </div>
          <div class="service-pricing card" style="margin-top: 24px;">
            <div class="pricing-row">
              <span class="pricing-item">LTO Records + DFA Apostille + DHL</span>
              <span class="pricing-amount">Contact for quote</span>
            </div>
            <p class="pricing-sub">Pricing varies based on specific documentation required. Contact us with your case details.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DFA Apostille -->
    <section class="bg-alt">
      <div class="container">
        <div class="service-detail">
          <div class="service-header">
            <span class="service-tag">DFA</span>
            <h2>{t("services.dfa.title")}</h2>
          </div>
          <p class="service-lead">DFA (Department of Foreign Affairs) apostille authentication is required to make Philippine government documents legally recognized in countries party to the Hague Apostille Convention — including the United States, Canada, and Australia. Without apostille, Philippine documents may be rejected by immigration authorities.</p>
          <div class="grid-2" style="margin-top: 32px;">
            <div class="card">
              <h3>What's Included</h3>
              <ul class="doc-list">
                <li>DFA apostille stamp on PSA, NBI, and other government documents</li>
                <li>Authentication of translated documents</li>
                <li>Coordination between DFA offices and document issuers</li>
                <li>Quality check before shipping</li>
                <li>DHL international shipping with tracking</li>
              </ul>
            </div>
            <div class="card">
              <h3>Why It Matters</h3>
              <ul class="doc-list">
                <li>Required by USCIS for foreign document submissions</li>
                <li>Mandatory for Canadian immigration (IRCC) submissions</li>
                <li>Required for Australian Department of Home Affairs</li>
                <li>Ensures documents are accepted without additional verification</li>
                <li>Prevents delays and rejections due to unauthenticated documents</li>
              </ul>
            </div>
          </div>
          <div class="service-pricing card" style="margin-top: 24px;">
            <div class="pricing-row">
              <span class="pricing-item">DFA Apostille (standalone)</span>
              <span class="pricing-amount">Included in all packages</span>
            </div>
            <p class="pricing-sub">All IGRS document packages include DFA apostille authentication. We handle the full chain: document procurement → apostille → international delivery.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Translation -->
    <section>
      <div class="container">
        <div class="service-detail">
          <div class="service-header">
            <span class="service-tag">Translation</span>
            <h2>{t("services.translation.title")}</h2>
          </div>
          <p class="service-lead">Philippine government documents are issued in Filipino or English. While English documents are typically accepted directly, some immigration filings require certified translations or explanatory notes for non-English portions. IGRS provides translation services as part of our full-service offering.</p>
          <div class="grid-2" style="margin-top: 32px;">
            <div class="card">
              <h3>What's Included</h3>
              <ul class="doc-list">
                <li>Certified translation of PSA certificates</li>
                <li>Translation of NBI Clearance annotations</li>
                <li>Notarized translations where required</li>
                <li>Translation review for accuracy and completeness</li>
                <li>Delivered together with original documents</li>
              </ul>
            </div>
            <div class="card">
              <h3>When You Need It</h3>
              <ul class="doc-list">
                <li>Documents with Filipino-language annotations</li>
                <li>Cases requiring explanatory translation for adjudicators</li>
                <li>Canadian immigration filings requiring French or certified English</li>
                <li>Any case where your client's documents contain non-English text</li>
              </ul>
            </div>
          </div>
          <div class="service-pricing card" style="margin-top: 24px;">
            <div class="pricing-row">
              <span class="pricing-item">Translation (per document)</span>
              <span class="pricing-amount">Contact for quote</span>
            </div>
            <p class="pricing-sub">Translation is available as an add-on to any document procurement order. Ask about bundled pricing.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={getLocalizedPath("/contact", lang)} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .service-detail {
    max-width: 900px;
    margin: 0 auto;
  }
  .service-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }
  .service-tag {
    background: var(--accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 4px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .service-lead {
    font-size: 1.05rem;
    color: var(--text-light);
    line-height: 1.8;
  }
  .doc-list {
    list-style: none;
    margin-top: 12px;
  }
  .doc-list li {
    padding: 6px 0;
    font-size: 0.95rem;
    color: var(--text-light);
    border-bottom: 1px solid var(--border);
    padding-left: 16px;
    position: relative;
  }
  .doc-list li:last-child {
    border-bottom: none;
  }
  .doc-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .service-pricing {
    background: var(--bg-alt);
  }
  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .pricing-item {
    font-weight: 600;
    font-size: 1rem;
  }
  .pricing-amount {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent);
  }
  .pricing-sub {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
