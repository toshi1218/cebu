---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "ja";
const t = useTranslations(lang);
---

<Layout title={t("site.title")} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("about.title")}</h1>
        <p>{t("about.sub")}</p>
      </div>
    </div>

    <!-- Company Table -->
    <section>
      <div class="container">
        <div class="company-table">
          <div class="company-row">
            <dl>
              <dt>{t("about.name.label")}</dt>
              <dd>{t("about.name.value")}</dd>
            </dl>
          </div>
          <div class="company-row">
            <dl>
              <dt>{t("about.founded.label")}</dt>
              <dd>{t("about.founded.value")}</dd>
            </dl>
          </div>
          <div class="company-row">
            <dl>
              <dt>{t("about.hq.label")}</dt>
              <dd>{t("about.hq.value")}</dd>
            </dl>
          </div>
          <div class="company-row">
            <dl>
              <dt>{t("about.cebu.label")}</dt>
              <dd>{t("about.cebu.value")}</dd>
            </dl>
          </div>
          <div class="company-row">
            <dl>
              <dt>{t("about.biz.label")}</dt>
              <dd>{t("about.biz.value")}</dd>
            </dl>
          </div>
          <div class="company-row">
            <dl>
              <dt>{t("about.ceo.label")}</dt>
              <dd>{t("about.ceo.value")}</dd>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>IGRSの強み</h2>
          <p>行政書士事務所・登録支援機関に選ばれ続ける実績</p>
        </div>
        <div class="stats-row">
          <div class="stat-item">
            <div class="stat-number">4週間</div>
            <div class="stat-label">標準納期</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">80%+</div>
            <div class="stat-label">法人・士業のお客様比率</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">週次</div>
            <div class="stat-label">進捗報告頻度</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section>
      <div class="container">
        <div class="mission-block">
          <div class="mission-text">
            <h2>私たちのミッション</h2>
            <p>
              行政書士事務所・登録支援機関の皆様が本来の業務に集中できるよう、フィリピン書類取得という専門業務を一括してお引き受けします。
            </p>
            <p>
              セブ島に実拠点を置く日本法人として、現地窓口への直接アクセスと日本の法人間取引基準を両立。個人ブローカーとは異なる信頼性と透明性で、継続的な業務パートナーとしてご活用いただいています。
            </p>
          </div>
          <div class="mission-points">
            <div class="card">
              <h3>日本法人としての信頼性</h3>
              <p>株式会社IGRSとして設立。請求書払い・案件台帳管理・週次報告など、法人間取引の標準に対応しています。</p>
            </div>
            <div class="card">
              <h3>セブ島の現地拠点</h3>
              <p>PSA・NBI・LTO・DFA各窓口へ直接出向ける実拠点をセブ市に構えています。オンライン不可の書類や窓口交渉にも対応。</p>
            </div>
            <div class="card">
              <h3>DHL国際発送</h3>
              <p>取得した書類はDHL国際便で日本の事務所へ直接お届け。追跡番号を共有し、受領確認まで責任を持って対応します。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={getLocalizedPath("/contact", lang)} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .stat-item {
    text-align: center;
  }
  .mission-block {
    max-width: 900px;
    margin: 0 auto;
  }
  .mission-text {
    margin-bottom: 40px;
  }
  .mission-text h2 {
    margin-bottom: 20px;
  }
  .mission-text p {
    color: var(--text-light);
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .mission-points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .mission-points .card h3 {
    margin-bottom: 10px;
    color: var(--primary);
  }
  .mission-points .card p {
    font-size: 0.95rem;
    color: var(--text-light);
  }
  @media (max-width: 768px) {
    .mission-points {
      grid-template-columns: 1fr;
    }
  }
</style>
