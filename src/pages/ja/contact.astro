---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "ja";
const t = useTranslations(lang);
---

<Layout title={t("site.title")} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="container">
        <h1>{t("contact.title")}</h1>
        <p>{t("contact.sub")}</p>
      </div>
    </div>

    <!-- Contact Info -->
    <section>
      <div class="container">
        <div class="contact-card card">
          <p class="contact-intro">{t("contact.text")}</p>

          <div class="contact-info-row">
            <span class="contact-label">{t("contact.email.label")}</span>
            <a href={`mailto:${t("contact.email")}`} class="email-link">{t("contact.email")}</a>
          </div>

          <div class="contact-info-row">
            <span class="contact-label">{t("contact.hours.label")}</span>
            <span class="contact-value">{t("contact.hours")}</span>
          </div>

          <div class="contact-note-box">
            <p>{t("contact.note")}</p>
          </div>

          <div class="inquiry-guide">
            <h3>お問い合わせ時にお知らせいただく内容</h3>
            <ul>
              <li>
                <span class="guide-icon">1</span>
                <div>
                  <strong>必要書類の種類</strong>
                  <p>PSA・NBI・LTO・DFA認証・翻訳など、必要な書類をお知らせください。</p>
                </div>
              </li>
              <li>
                <span class="guide-icon">2</span>
                <div>
                  <strong>件数・対象人数</strong>
                  <p>何名分の書類が必要かをお知らせください。10名以上は別途見積もりいたします。</p>
                </div>
              </li>
              <li>
                <span class="guide-icon">3</span>
                <div>
                  <strong>ご希望の納期</strong>
                  <p>書類提出期限・在留資格申請予定日などをお知らせください。標準納期は4週間です。</p>
                </div>
              </li>
              <li>
                <span class="guide-icon">4</span>
                <div>
                  <strong>提出先</strong>
                  <p>入管局・法務局・市区町村役場・運転免許試験場など、書類の提出先をお知らせいただけると最適なプランをご提案できます。</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA with direct email -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={`mailto:${t("contact.email")}`} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .contact-card {
    max-width: 640px;
    margin: 0 auto;
    padding: 40px;
  }
  .contact-intro {
    color: var(--text-light);
    margin-bottom: 32px;
    line-height: 1.8;
  }
  .contact-info-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .contact-info-row:last-of-type {
    border-bottom: none;
  }
  .contact-label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    white-space: nowrap;
    min-width: 80px;
  }
  .contact-value {
    font-size: 1rem;
    color: var(--text-light);
  }
  .contact-note-box {
    margin: 24px 0;
    padding: 14px 20px;
    background: var(--bg-alt);
    border-radius: var(--radius);
    border-left: 3px solid var(--accent);
  }
  .contact-note-box p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .inquiry-guide {
    margin-top: 32px;
  }
  .inquiry-guide h3 {
    font-size: 1.05rem;
    margin-bottom: 20px;
    color: var(--primary);
  }
  .inquiry-guide ul {
    list-style: none;
    display: grid;
    gap: 16px;
  }
  .inquiry-guide li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .guide-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .inquiry-guide li strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 4px;
    color: var(--text);
  }
  .inquiry-guide li p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
