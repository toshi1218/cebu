---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "ja";
const t = useTranslations(lang);
---

<Layout
  title={t("site.title")}
  description={t("site.description")}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <h1 class="hero-title">
          {t("hero.title")}<br />
          <span class="hero-accent">{t("hero.title.accent")}</span>
        </h1>
        <p class="hero-subtitle">{t("hero.subtitle")}</p>
        <div class="cta-group">
          <a href={getLocalizedPath("/contact", lang)} class="btn btn-cta">
            {t("hero.cta")}
          </a>
          <a href={getLocalizedPath("/services", lang)} class="btn btn-outline">
            {t("hero.cta.secondary")}
          </a>
        </div>
      </div>
    </section>

    <!-- Problems -->
    <section class="bg-light">
      <div class="container">
        <h2 class="section-title">{t("problems.title")}</h2>
        <div class="problems-card card">
          <ul class="problems-list">
            <li class="problems-item">
              <span class="problem-check">✓</span>
              {t("problems.1")}
            </li>
            <li class="problems-item">
              <span class="problem-check">✓</span>
              {t("problems.2")}
            </li>
            <li class="problems-item">
              <span class="problem-check">✓</span>
              {t("problems.3")}
            </li>
            <li class="problems-item">
              <span class="problem-check">✓</span>
              {t("problems.4")}
            </li>
            <li class="problems-item">
              <span class="problem-check">✓</span>
              {t("problems.5")}
            </li>
          </ul>
          <p class="problems-footer">
            IGRSはこれらすべての課題を解決するワンストップBPOサービスです。
          </p>
        </div>
      </div>
    </section>

    <!-- Why IGRS -->
    <section>
      <div class="container">
        <h2 class="section-title">{t("why.title")}</h2>
        <div class="why-grid">
          <div class="card why-card">
            <div class="why-number">01</div>
            <h3 class="why-card-title">{t("why.1.title")}</h3>
            <p>{t("why.1.text")}</p>
          </div>
          <div class="card why-card">
            <div class="why-number">02</div>
            <h3 class="why-card-title">{t("why.2.title")}</h3>
            <p>{t("why.2.text")}</p>
          </div>
          <div class="card why-card">
            <div class="why-number">03</div>
            <h3 class="why-card-title">{t("why.3.title")}</h3>
            <p>{t("why.3.text")}</p>
          </div>
          <div class="card why-card">
            <div class="why-number">04</div>
            <h3 class="why-card-title">{t("why.4.title")}</h3>
            <p>{t("why.4.text")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="bg-light">
      <div class="container">
        <h2 class="section-title">{t("services.title")}</h2>
        <div class="services-grid">
          <a href={getLocalizedPath("/services#psa", lang)} class="card service-card">
            <div class="service-badge">PSA</div>
            <h3 class="service-card-title">{t("services.psa.title")}</h3>
            <p class="service-card-desc">{t("services.psa.desc")}</p>
          </a>
          <a href={getLocalizedPath("/services#nbi", lang)} class="card service-card">
            <div class="service-badge">NBI</div>
            <h3 class="service-card-title">{t("services.nbi.title")}</h3>
            <p class="service-card-desc">{t("services.nbi.desc")}</p>
          </a>
          <a href={getLocalizedPath("/services#lto", lang)} class="card service-card">
            <div class="service-badge">LTO</div>
            <h3 class="service-card-title">{t("services.lto.title")}</h3>
            <p class="service-card-desc">{t("services.lto.desc")}</p>
          </a>
          <a href={getLocalizedPath("/services#dfa", lang)} class="card service-card">
            <div class="service-badge">DFA</div>
            <h3 class="service-card-title">{t("services.dfa.title")}</h3>
            <p class="service-card-desc">{t("services.dfa.desc")}</p>
          </a>
          <a href={getLocalizedPath("/services#translation", lang)} class="card service-card">
            <div class="service-badge">翻訳</div>
            <h3 class="service-card-title">{t("services.translation.title")}</h3>
            <p class="service-card-desc">{t("services.translation.desc")}</p>
          </a>
        </div>
        <div class="section-cta">
          <a href={getLocalizedPath("/services", lang)} class="btn btn-primary-outline">
            サービス詳細を見る
          </a>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section>
      <div class="container">
        <h2 class="section-title">{t("usecases.title")}</h2>
        <div class="usecases-grid">
          <div class="card usecase-card">
            <h3 class="usecase-title">{t("usecases.1.title")}</h3>
            <p>{t("usecases.1.desc")}</p>
          </div>
          <div class="card usecase-card">
            <h3 class="usecase-title">{t("usecases.2.title")}</h3>
            <p>{t("usecases.2.desc")}</p>
          </div>
          <div class="card usecase-card">
            <h3 class="usecase-title">{t("usecases.3.title")}</h3>
            <p>{t("usecases.3.desc")}</p>
          </div>
          <div class="card usecase-card">
            <h3 class="usecase-title">{t("usecases.4.title")}</h3>
            <p>{t("usecases.4.desc")}</p>
          </div>
          <div class="card usecase-card">
            <h3 class="usecase-title">{t("usecases.5.title")}</h3>
            <p>{t("usecases.5.desc")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="bg-light">
      <div class="container">
        <h2 class="section-title">{t("pricing.title")}</h2>
        <div class="pricing-grid">
          <div class="pricing-card">
            <div class="plan-name">{t("pricing.light.name")}</div>
            <div class="plan-price">
              {t("pricing.light.price")}
              <span class="plan-unit">{t("pricing.light.unit")}</span>
            </div>
            <p class="plan-desc">{t("pricing.light.desc")}</p>
            <span class="plan-delivery">{t("pricing.delivery")}</span>
          </div>
          <div class="pricing-card featured">
            <div class="featured-badge">人気</div>
            <div class="plan-name">{t("pricing.pack.name")}</div>
            <div class="plan-price">
              {t("pricing.pack.price")}
              <span class="plan-unit">{t("pricing.pack.unit")}</span>
            </div>
            <p class="plan-desc">{t("pricing.pack.desc")}</p>
            <span class="plan-delivery">{t("pricing.delivery")}</span>
          </div>
          <div class="pricing-card">
            <div class="plan-name">{t("pricing.nbi.name")}</div>
            <div class="plan-price">
              {t("pricing.nbi.price")}
              <span class="plan-unit">{t("pricing.nbi.unit")}</span>
            </div>
            <p class="plan-desc">{t("pricing.nbi.desc")}</p>
            <span class="plan-delivery">{t("pricing.delivery")}</span>
          </div>
        </div>
        <p class="pricing-note">{t("pricing.note")}</p>
      </div>
    </section>

    <!-- Flow -->
    <section>
      <div class="container">
        <h2 class="section-title">{t("flow.title")}</h2>
        <div class="flow-steps">
          <div class="flow-step">
            <div class="flow-step-number">01</div>
            <div class="flow-step-content">
              <h3 class="flow-step-title">{t("flow.1.title")}</h3>
              <p>{t("flow.1.desc")}</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-step-number">02</div>
            <div class="flow-step-content">
              <h3 class="flow-step-title">{t("flow.2.title")}</h3>
              <p>{t("flow.2.desc")}</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-step-number">03</div>
            <div class="flow-step-content">
              <h3 class="flow-step-title">{t("flow.3.title")}</h3>
              <p>{t("flow.3.desc")}</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-step-number">04</div>
            <div class="flow-step-content">
              <h3 class="flow-step-title">{t("flow.4.title")}</h3>
              <p>{t("flow.4.desc")}</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-step-number">05</div>
            <div class="flow-step-content">
              <h3 class="flow-step-title">{t("flow.5.title")}</h3>
              <p>{t("flow.5.desc")}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-light">
      <div class="container">
        <h2 class="section-title">{t("faq.title")}</h2>
        <div class="faq-grid">
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.1.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.1.a")}
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.2.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.2.a")}
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.3.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.3.a")}
            </div>
          </div>
          <div class="card faq-card">
            <div class="faq-q">
              <span class="faq-label">Q</span>
              {t("faq.4.q")}
            </div>
            <div class="faq-a">
              <span class="faq-label faq-label-a">A</span>
              {t("faq.4.a")}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container cta-inner">
        <h2 class="cta-heading">{t("cta.title")}</h2>
        <p class="cta-text">{t("cta.text")}</p>
        <div class="cta-group">
          <a href={getLocalizedPath("/contact", lang)} class="btn btn-cta btn-lg">
            {t("cta.button")}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  /* Hero */
  .hero {
    background-color: var(--primary-color);
    padding: 5rem 0 4rem;
  }

  .hero-inner {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.75rem;
    color: #ffffff;
    margin-bottom: 1.25rem;
    line-height: 1.25;
  }

  .hero-accent {
    color: var(--accent-color);
    display: inline-block;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  /* Problems */
  .problems-card {
    max-width: 760px;
    margin: 0 auto;
  }

  .problems-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problems-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--text-dark);
    line-height: 1.5;
  }

  .problem-check {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background-color: var(--accent-color);
    color: #000000;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    margin-top: 0.05rem;
  }

  .problems-footer {
    font-size: 0.95rem;
    font-weight: var(--font-weight-semibold);
    color: var(--primary-color);
    border-top: 1px solid var(--border-color);
    padding-top: 1.25rem;
    margin-bottom: 0;
    text-align: center;
  }

  /* Why Grid */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .why-card {
    position: relative;
  }

  .why-number {
    font-size: 2.5rem;
    font-weight: var(--font-weight-bold);
    color: var(--border-color);
    line-height: 1;
    margin-bottom: 0.5rem;
    font-feature-settings: "tnum";
  }

  .why-card-title {
    color: var(--primary-color);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  /* Service Cards */
  .service-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .service-card:hover {
    color: inherit;
  }

  .service-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background-color: var(--primary-color);
    color: #ffffff;
    border-radius: var(--border-radius-sm);
    font-size: 0.8rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .service-card-title {
    font-size: 1rem;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
  }

  .service-card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .section-cta {
    text-align: center;
    margin-top: 2rem;
  }

  .btn-primary-outline {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: var(--border-radius-md);
    font-weight: var(--font-weight-semibold);
    font-size: 1rem;
    text-decoration: none;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .btn-primary-outline:hover {
    background-color: var(--primary-color);
    color: #ffffff;
    transform: translateY(-1px);
  }

  /* Use Cases */
  .usecases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .usecase-card {
    border-top: 3px solid var(--accent-color);
  }

  .usecase-title {
    font-size: 1rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  /* Pricing */
  .pricing-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .featured-badge {
    display: inline-block;
    background-color: var(--accent-color);
    color: #000000;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    padding: 0.15rem 0.5rem;
    border-radius: var(--border-radius-sm);
    margin-bottom: 0.5rem;
  }

  /* Flow */
  .flow-steps {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .flow-step {
    flex: 1;
    min-width: 140px;
    max-width: 200px;
    text-align: center;
    padding: 1.5rem 1rem;
    background-color: var(--bg-white);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .flow-step-number {
    font-size: 1.75rem;
    font-weight: var(--font-weight-bold);
    color: var(--accent-color);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .flow-step-title {
    font-size: 0.95rem;
    color: var(--primary-color);
    margin-bottom: 0.4rem;
  }

  .flow-step-content p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0;
    line-height: 1.5;
  }

  .flow-arrow {
    font-size: 1.5rem;
    color: var(--border-color);
    align-self: center;
    flex-shrink: 0;
    padding-top: 0;
  }

  /* FAQ */
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .faq-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-q,
  .faq-a {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .faq-q {
    font-weight: var(--font-weight-semibold);
    color: var(--text-dark);
  }

  .faq-a {
    color: var(--text-light);
  }

  .faq-label {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background-color: var(--primary-color);
    color: #ffffff;
    border-radius: var(--border-radius-sm);
    font-size: 0.8rem;
    font-weight: var(--font-weight-bold);
  }

  .faq-label-a {
    background-color: var(--accent-color);
    color: #000000;
  }

  /* CTA Section */
  .cta-section {
    background-color: var(--primary-color);
    padding: 4rem 0;
  }

  .cta-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-heading {
    color: #ffffff;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .cta-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: 1.05rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 2.5rem;
    }

    .hero-title {
      font-size: 1.9rem;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .flow-steps {
      flex-direction: column;
      align-items: center;
    }

    .flow-step {
      max-width: 100%;
      width: 100%;
    }

    .flow-arrow {
      transform: rotate(90deg);
    }

    .faq-grid {
      grid-template-columns: 1fr;
    }

    .cta-heading {
      font-size: 1.4rem;
    }
  }
</style>
