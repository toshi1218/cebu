---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = "ja";
const t = useTranslations(lang);
---

<Layout title={t("site.title")} description={t("site.description")} lang={lang}>
  <Header lang={lang} />
  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <span class="hero-label">{t("hero.label")}</span>
        <h1>
          {t("hero.title")}<br />
          <span class="accent">{t("hero.accent")}</span>
        </h1>
        <p>{t("hero.sub")}</p>
        <div class="cta-group">
          <a href={getLocalizedPath("/contact", lang)} class="btn btn-primary">{t("hero.cta")}</a>
          <a href={getLocalizedPath("/services", lang)} class="btn btn-outline">{t("hero.cta2")}</a>
        </div>
        <div class="trust-badges">
          <span class="trust-badge">✓ {t("trust.1")}</span>
          <span class="trust-badge">✓ {t("trust.2")}</span>
          <span class="trust-badge">✓ {t("trust.3")}</span>
          <span class="trust-badge">✓ {t("trust.4")}</span>
        </div>
      </div>
    </section>

    <!-- Problems -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>{t("problems.title")}</h2>
        </div>
        <ul class="problems-list">
          <li><span class="check-icon">✓</span>{t("problems.1")}</li>
          <li><span class="check-icon">✓</span>{t("problems.2")}</li>
          <li><span class="check-icon">✓</span>{t("problems.3")}</li>
          <li><span class="check-icon">✓</span>{t("problems.4")}</li>
          <li><span class="check-icon">✓</span>{t("problems.5")}</li>
        </ul>
      </div>
    </section>

    <!-- Why IGRS -->
    <section>
      <div class="container">
        <div class="section-title">
          <h2>{t("why.title")}</h2>
        </div>
        <div class="grid-2">
          <div class="card">
            <h3>{t("why.1.title")}</h3>
            <p>{t("why.1.text")}</p>
          </div>
          <div class="card">
            <h3>{t("why.2.title")}</h3>
            <p>{t("why.2.text")}</p>
          </div>
          <div class="card">
            <h3>{t("why.3.title")}</h3>
            <p>{t("why.3.text")}</p>
          </div>
          <div class="card">
            <h3>{t("why.4.title")}</h3>
            <p>{t("why.4.text")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>{t("services.title")}</h2>
        </div>
        <div class="grid-3">
          <div class="card">
            <div class="svc-icon">📄</div>
            <h3>{t("services.psa.title")}</h3>
            <p>{t("services.psa.desc")}</p>
          </div>
          <div class="card">
            <div class="svc-icon">🔍</div>
            <h3>{t("services.nbi.title")}</h3>
            <p>{t("services.nbi.desc")}</p>
          </div>
          <div class="card">
            <div class="svc-icon">🚗</div>
            <h3>{t("services.lto.title")}</h3>
            <p>{t("services.lto.desc")}</p>
          </div>
          <div class="card">
            <div class="svc-icon">🌐</div>
            <h3>{t("services.dfa.title")}</h3>
            <p>{t("services.dfa.desc")}</p>
          </div>
          <div class="card">
            <div class="svc-icon">📝</div>
            <h3>{t("services.translation.title")}</h3>
            <p>{t("services.translation.desc")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section>
      <div class="container">
        <div class="section-title">
          <h2>{t("pricing.title")}</h2>
        </div>
        <div class="pricing-grid">
          <div class="pricing-card card">
            <h3>{t("pricing.1.name")}</h3>
            <div class="pricing-price">{t("pricing.1.price")}</div>
            <p>{t("pricing.1.desc")}</p>
          </div>
          <div class="pricing-card card featured">
            <h3>{t("pricing.2.name")}</h3>
            <div class="pricing-price">{t("pricing.2.price")}</div>
            <p>{t("pricing.2.desc")}</p>
          </div>
          <div class="pricing-card card">
            <h3>{t("pricing.3.name")}</h3>
            <div class="pricing-price">{t("pricing.3.price")}</div>
            <p>{t("pricing.3.desc")}</p>
          </div>
        </div>
        <p class="pricing-note">{t("pricing.note")}</p>
      </div>
    </section>

    <!-- Flow -->
    <section class="bg-alt">
      <div class="container">
        <div class="section-title">
          <h2>{t("flow.title")}</h2>
        </div>
        <div class="flow-steps">
          <div class="flow-step">
            <div>
              <h3>{t("flow.1")}</h3>
              <p>{t("flow.1.desc")}</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>{t("flow.2")}</h3>
              <p>{t("flow.2.desc")}</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>{t("flow.3")}</h3>
              <p>{t("flow.3.desc")}</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>{t("flow.4")}</h3>
              <p>{t("flow.4.desc")}</p>
            </div>
          </div>
          <div class="flow-step">
            <div>
              <h3>{t("flow.5")}</h3>
              <p>{t("flow.5.desc")}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <div class="container">
        <div class="section-title">
          <h2>{t("faq.title")}</h2>
        </div>
        <div class="faq-list">
          <div class="faq-item card">
            <h3>{t("faq.1.q")}</h3>
            <p>{t("faq.1.a")}</p>
          </div>
          <div class="faq-item card">
            <h3>{t("faq.2.q")}</h3>
            <p>{t("faq.2.a")}</p>
          </div>
          <div class="faq-item card">
            <h3>{t("faq.3.q")}</h3>
            <p>{t("faq.3.a")}</p>
          </div>
          <div class="faq-item card">
            <h3>{t("faq.4.q")}</h3>
            <p>{t("faq.4.a")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="cta-section">
      <div class="container">
        <h2>{t("cta.title")}</h2>
        <p>{t("cta.text")}</p>
        <a href={getLocalizedPath("/contact", lang)} class="btn btn-primary">{t("cta.button")}</a>
      </div>
    </div>

  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .svc-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .pricing-note {
    text-align: center;
    margin-top: 24px;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
